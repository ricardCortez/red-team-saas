# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
DEBUG=true
PROJECT_NAME=Red Team SaaS
PROJECT_VERSION=0.1.0
API_V1_STR=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://redteam:password@localhost:5432/redteam_db
POSTGRES_USER=redteam
POSTGRES_PASSWORD=password
POSTGRES_DB=redteam_db
DB_ECHO=true

# =============================================================================
# Redis / Celery
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# Security / JWT
# =============================================================================
SECRET_KEY=change-me-to-a-random-64-char-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENCRYPTION_KEY=your-encryption-key-change-in-production

# =============================================================================
# API
# =============================================================================
API_BASE_URL=http://localhost:8000

# =============================================================================
# AWS S3
# =============================================================================
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=redteam-saas-bucket

# =============================================================================
# GitHub OAuth
# =============================================================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# =============================================================================
# Google OAuth
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# Slack
# =============================================================================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# =============================================================================
# SMTP / Email
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@readteam.dev

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
ALLOW_CREDENTIALS=true

# =============================================================================
# Docker Registry (for staging/production)
# =============================================================================
REGISTRY=ghcr.io/your-org
VERSION=latest
