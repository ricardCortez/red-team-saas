def _finding(
    severity="critical",
    status="open",
    tool_name="nmap",
    risk_score=8.0,
    created_at=None,
    updated_at=None,
    is_duplicate=False,
    project_id=1,
):
    f = MagicMock()
    f.severity = MagicMock()
    f.severity.value = severity
    f.status = MagicMock()
    f.status.value = status
    f.tool_name = tool_name
    f.risk_score = risk_score
    f.project_id = project_id
    f.is_duplicate = is_duplicate
    f.created_at = created_at or datetime(2026, 1, 1)
    f.updated_at = updated_at or datetime(2026, 1, 5)
    f.host = "10.0.0.1"
    return f


