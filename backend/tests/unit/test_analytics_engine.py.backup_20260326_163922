class TestCalculateMTTR:

    def _engine(self, findings):
        from app.services.analytics_engine import AnalyticsEngine
        db = MagicMock()
        db.query.return_value.filter.return_value.all.return_value = findings
        return AnalyticsEngine(db)

    def test_mttr_no_resolved_findings(self):
        engine = self._engine([])
        mttr, trend = engine.calculate_mttr(1)
        assert mttr is None
        assert trend == 0.0

    def test_mttr_single_resolved(self):
        f = _finding(status="resolved")
        f.created_at = datetime(2026, 1, 1, 0, 0, 0)
        f.updated_at = datetime(2026, 1, 1, 4, 0, 0)  # 4 hours
        engine = self._engine([f])
        mttr, trend = engine.calculate_mttr(1)
        assert mttr == pytest.approx(4.0)
        assert trend == 0.0

    def test_mttr_multiple_resolved_calculates_mean(self):
        findings = []
        for hours in [2, 4, 6]:
            f = _finding(status="resolved")
            f.created_at = datetime(2026, 1, 1)
            f.updated_at = datetime(2026, 1, 1) + timedelta(hours=hours)
            findings.append(f)

        engine = self._engine(findings)
        mttr, trend = engine.calculate_mttr(1)
        assert mttr == pytest.approx(4.0)  # mean of [2, 4, 6]

    def test_mttr_ignores_findings_without_dates(self):
        f = _finding(status="resolved")
        f.created_at = None
        f.updated_at = None
        engine = self._engine([f])
