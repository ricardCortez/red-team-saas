class TestRealtimeMetricsService:

    def _service(self):
        with patch("app.services.realtime_metrics.redis_client") as mock_redis:
            from app.services.realtime_metrics import RealtimeMetricsService
            svc = RealtimeMetricsService()
            svc.redis = mock_redis
            return svc, mock_redis

    def test_increment_calls_incrby_and_expire(self):
        svc, mock_redis = self._service()
        svc.increment_metric("proj-1", "findings_created", 3)
        mock_redis.incrby.assert_called_once_with("metrics:proj-1:findings_created", 3)
        mock_redis.expire.assert_called_once()

    def test_get_metric_returns_int(self):
        svc, mock_redis = self._service()
        mock_redis.get.return_value = "7"
        assert svc.get_metric("proj-1", "findings_created") == 7

    def test_get_metric_returns_zero_if_absent(self):
        svc, mock_redis = self._service()
        mock_redis.get.return_value = None
        assert svc.get_metric("proj-1", "missing") == 0

    def test_increment_tool_metric_uses_correct_key(self):
        svc, mock_redis = self._service()
        svc.increment_tool_metric("proj-1", "nmap", "invocations", 5)
        expected_key = "metrics:proj-1:tool:nmap:invocations"
        mock_redis.incrby.assert_called_once_with(expected_key, 5)

    def test_get_tool_metrics_parses_keys(self):
        svc, mock_redis = self._service()
        mock_redis.keys.return_value = [
            "metrics:proj-1:tool:nmap:invocations",
            "metrics:proj-1:tool:nmap:findings",
        ]
        mock_redis.mget.return_value = ["3", "12"]
        result = svc.get_tool_metrics("proj-1", "nmap")
        assert result["invocations"] == 3
        assert result["findings"]    == 12

    def test_get_current_metrics_returns_dict(self):
        svc, mock_redis = self._service()
        mock_redis.keys.return_value = [
            "metrics:proj-1:findings_created",
            "metrics:proj-1:scans_executed",
        ]
        mock_redis.mget.return_value = ["5", "2"]
        result = svc.get_current_metrics("proj-1")
        assert result["findings_created"] == 5
        assert result["scans_executed"]   == 2

    def test_reset_deletes_all_project_keys(self):
        svc, mock_redis = self._service()
        mock_redis.keys.return_value = ["metrics:p:a", "metrics:p:b"]
        count = svc.reset_project_metrics("p")
        mock_redis.delete.assert_called_once_with("metrics:p:a", "metrics:p:b")
        assert count == 2

    def test_health_check_ok(self):
        svc, mock_redis = self._service()
        mock_redis.ping.return_value = True
        assert svc.health_check() is True

    def test_health_check_failure(self):
        svc, mock_redis = self._service()
        mock_redis.ping.side_effect = Exception("Connection refused")
        assert svc.health_check() is False

    def test_set_gauge_uses_float_str(self):
        svc, mock_redis = self._service()
        svc.set_gauge("proj-1", "risk_score", 72.5)
        mock_redis.set.assert_called_once_with(
