def test_dispatch_project_analytics_calls_subtasks(test_db):
    """Test que dispatch_project_analytics enqueue KPI y risk score subtasks"""
    from unittest.mock import patch, call
    from uuid import uuid4
    from app.models.project import Project
    
    # Crear proyecto
    project = Project(
        name="Test Project",
        owner_id=uuid4()
    )
    test_db.add(project)
    test_db.commit()
    
    # Mock ambas tareas
    with patch('app.tasks.analytics_tasks.calculate_kpis_for_project.delay') as mock_kpi:
        with patch('app.tasks.analytics_tasks.calculate_risk_score_for_project.delay') as mock_risk:
            # Importar despu茅s de patchear
            from app.tasks.analytics_tasks import dispatch_project_analytics
            
            # Ejecutar dispatch
            dispatch_project_analytics()
            
            # Verificar que se llamaron
            assert mock_kpi.called, "calculate_kpis_for_project.delay() not called"
            assert mock_risk.called, "calculate_risk_score_for_project.delay() not called"
            
            # Ambos deben haber sido llamados con el project_id
            assert mock_kpi.call_count >= 1, "KPI task not called"
            assert mock_risk.call_count >= 1, "Risk task not called"


def test_dispatch_daily_snapshots_calls_snapshot_task(test_db):
    """Test que dispatch_daily_snapshots enqueue snapshot tasks para cada proyecto"""
    from unittest.mock import patch
    from uuid import uuid4
    from app.models.project import Project
    
    # Crear 2 proyectos activos
    project1 = Project(name="Project 1", owner_id=uuid4())
    project2 = Project(name="Project 2", owner_id=uuid4())
    test_db.add_all([project1, project2])
    test_db.commit()
    
    with patch('app.tasks.analytics_tasks.create_daily_snapshot.delay') as mock_snapshot:
        # Importar despu茅s de patchear
        from app.tasks.analytics_tasks import dispatch_daily_snapshots
        
        # Ejecutar dispatch
        dispatch_daily_snapshots()
        
        # Debe llamarse al menos una vez por proyecto
        assert mock_snapshot.called, "create_daily_snapshot.delay() not called"
        assert mock_snapshot.call_count >= 2, \
            f"Expected at least 2 calls (one per project), got {mock_snapshot.call_count}"


