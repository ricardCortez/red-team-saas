def test_upsert_benchmark_updates_existing(test_db):
    """Test upsert de benchmark data actualiza valores existentes"""
    from app.crud.analytics import AnalyticsCRUD
    from app.models.analytics import BenchmarkData
    
    # Crear benchmark inicial
    benchmark1 = BenchmarkData(
        metric_name="MTTR",
        industry="finance",
        company_size="enterprise",
        average_value=4.5,
        median_value=3.0,
        p75_value=6.0,
        p90_value=8.0,
        sample_size=150
    )
    test_db.add(benchmark1)
    test_db.commit()
    initial_id = benchmark1.id
    
    # Upsert con nuevos valores - en este caso crear uno nuevo pero con merge
    benchmark2_data = {
        "metric_name": "MTTR",
        "industry": "finance",
        "company_size": "enterprise",
        "average_value": 5.2,  # Updated
        "median_value": 3.5,
        "p75_value": 7.0,
        "p90_value": 9.0,
        "sample_size": 175
    }
    
    # Buscar existente y actualizar, o crear
    existing = test_db.query(BenchmarkData).filter(
        BenchmarkData.metric_name == "MTTR",
        BenchmarkData.industry == "finance",
        BenchmarkData.company_size == "enterprise"
    ).first()
    
    if existing:
        existing.average_value = benchmark2_data["average_value"]
        existing.median_value = benchmark2_data["median_value"]
        existing.p75_value = benchmark2_data["p75_value"]
        existing.p90_value = benchmark2_data["p90_value"]
        existing.sample_size = benchmark2_data["sample_size"]
    else:
        new_benchmark = BenchmarkData(**benchmark2_data)
        test_db.add(new_benchmark)
    
    test_db.commit()
    
    # Verificar que se actualiz贸
    result = test_db.query(BenchmarkData).filter(
        BenchmarkData.metric_name == "MTTR",
        BenchmarkData.industry == "finance",
        BenchmarkData.company_size == "enterprise"
    ).first()
    
    assert result is not None, "Benchmark not found"
    assert result.average_value == 5.2, f"Expected 5.2, got {result.average_value}"
    assert result.sample_size == 175, f"Expected 175, got {result.sample_size}"
    assert result.id == initial_id, "ID changed, should be same record"


